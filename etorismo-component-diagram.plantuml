@startuml Component Diagram - ETorismo

package "Mobile App" {
  component [App.js] as MobileApp
  component [index.js] as MobileIndex
  
  package "Navigation" {
    component [AuthNavigator] as AuthNav
    component [TabNavigator] as TabNav
  }
  
  package "Auth Screens" {
    component [AppIntro] as AppIntro
    component [GetStarted] as GetStarted
    component [SignIn] as SignIn
    component [SignUp] as SignUp
  }
  
  package "Main Screens" {
    component [Home] as Home
    component [Artifacts] as Artifacts
    component [LiveMass] as LiveMass
    component [modal_artifacts] as ModalArtifacts
    component [Profile] as Profile
    component [QRScanner] as QRScanner
    component [Settings] as Settings
  }
  
  package "Shared UI Components" {
    component [Button] as Button
    component [Card] as Card
    component [Header] as Header
    component [Input] as Input
    component [Modal] as Modal
    component [TabBar] as TabBar
    component [SearchBar] as SearchBar
    component [Avatar] as Avatar
    component [Badge] as Badge
    component [Divider] as Divider
    component [ErrorMessage] as ErrorMessage
    component [Loading] as Loading
    component [Toast] as Toast
    component [ListItem] as ListItem
    component [AnimatedTabBar] as AnimatedTabBar
    component [FloatingTabBar] as FloatingTabBar
  }
  
  package "Services" {
    component [authService] as AuthService
    component [supabase] as SupabaseService
    component [websocket] as WebSocketService
  }
  
  package "Store" {
    component [useAuthStore] as AuthStore
  }
}

package "Admin Dashboard" {
  component [App.tsx] as AdminApp
  component [main.tsx] as AdminMain
  
  package "Pages" {
    component [DashboardPage] as DashboardPage
    component [UsersPage] as UsersPage
    component [EventsPage] as EventsPage
    component [ArtifactsPage] as ArtifactsPage
    component [AudioGuidesPage] as AudioGuidesPage
    component [QrPage] as QrPage
    component [AnnouncementsPage] as AnnouncementsPage
    component [RatingsPage] as RatingsPage
    component [SettingsPage] as SettingsPage
    component [LoginPage] as LoginPage
  }
  
  package "Components" {
    component [Sidebar] as Sidebar
    component [DashboardMetricCard] as DashboardMetricCard
    component [DashboardDemographics] as DashboardDemographics
    component [Modal] as Modal
  }
  
  package "Services" {
    component [supabase] as AdminSupabase
  }
}

package "External Services" {
  component [Supabase Backend] as SupabaseBackend
  component [Authentication Flow] as AuthFlow
  component [Realtime/WebSocket] as RealtimeWS
  component [Translations] as Translations
  component [Audio Guides] as AudioGuides
}

